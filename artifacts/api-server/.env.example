# =============================================================================
# 1 Minute Ludo — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# Node environment: development | production | test
NODE_ENV=development

# Port the Express server listens on (injected by Replit workflow in dev)
PORT=5000

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/one_minute_ludo

# Secret used to sign sessions (use a long random string in production)
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Allowed CORS origin(s) for the API and Socket.IO
# Use * for development, restrict to your domain in production
CORS_ORIGIN=*

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
