# =============================================================================
# 1 Minute Ludo — Root .gitignore
# =============================================================================

# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Node / pnpm ──────────────────────────────────────────────────────────────
node_modules/
dist/
build/
*.tsbuildinfo
.tsbuildinfo
pnpm-lock.yaml.bak

# ── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# ── Flutter ──────────────────────────────────────────────────────────────────
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/.packages
flutter_app/build/
flutter_app/android/local.properties
flutter_app/android/.gradle/
flutter_app/android/captures/
flutter_app/android/key.jks
flutter_app/android/key.properties
flutter_app/ios/Pods/
flutter_app/ios/.symlinks/

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

# ── Uploads (binary assets — do not commit) ──────────────────────────────────
backend/uploads/avatars/*
!backend/uploads/avatars/.gitkeep

# ── Replit ───────────────────────────────────────────────────────────────────
.replit
replit.nix
