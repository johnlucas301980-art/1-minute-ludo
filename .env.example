# =============================================================================
# 1 Minute Ludo — Root Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/one_minute_ludo

# Session signing secret (generate a strong random string for production)
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Allowed CORS origin — use * for dev, set your domain in production
CORS_ORIGIN=*

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
